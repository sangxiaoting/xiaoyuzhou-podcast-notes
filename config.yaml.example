# RSSHub 实例地址（可替换为自部署实例）
rsshub_base: "https://rsshub.rssforever.com"

# 小宇宙播客订阅列表
# 以下为推荐播客示例，你可以自行增删改
# RSS 地址使用 RSSHub 代理格式: {rsshub_base}/xiaoyuzhou/podcast/<ID>
podcasts:
  - name: "硅谷101"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/5e5c52c9418a84a04625e6cc"
  - name: "What's Next|科技早知道"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/5e74b52c418a84a046ecaceb"
  - name: "张小珺Jun|商业访谈录"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/626b46ea9cbbf0451cf5a962"
  - name: "声动早咖啡"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/60de7c003dd577b40d5a40f3"
  - name: "OnBoard!"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/61cbaac48bb4cd867fcabe22"
  - name: "创业内幕"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/5e7cccf8418a84a046c4e7f9"
  - name: "商业就是这样"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/6022a180ef5fdaddc30bb101"
  - name: "科技乱炖"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/5e4243cd418a84a0469573fb"
  - name: "三五环"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/5e280fab418a84a0461faa3c"
  - name: "疯投圈"
    rss: "https://rsshub.rssforever.com/xiaoyuzhou/podcast/5e280faf418a84a0461fbd39"

# 过滤规则
filter:
  min_duration_minutes: 10    # 跳过短于 10 分钟的节目
  max_episodes_per_run: 5     # 每次最多处理 5 期

# 输出目录（转录文本和 Markdown 笔记）
output_dir: "~/Desktop/podcast-notes"

# Whisper 模型（Apple Silicon 本地推理）
whisper_model: "large-v3-turbo"

# LLM 提炼配置（可选）
# 配置后 run/process 会自动调用 LLM 将转录文本提炼为结构化 Markdown
# 不配置则仅执行转录，提炼步骤需在 Claude Code 中完成
#
# llm:
#   provider: "anthropic"                      # anthropic / openai / deepseek / kimi
#   model: "claude-sonnet-4-20250514"           # 模型名称
#   api_key: "sk-..."                           # API key（也可通过环境变量设置）
#   base_url: ""                                # 可选，自定义 API 端点
#
# --- 各 provider 配置示例 ---
#
# Anthropic (Claude):
# llm:
#   provider: "anthropic"
#   model: "claude-sonnet-4-20250514"
#   api_key: ""                                 # 或设置环境变量 ANTHROPIC_API_KEY
#
# OpenAI (GPT):
# llm:
#   provider: "openai"
#   model: "gpt-4o"
#   api_key: ""                                 # 或设置环境变量 OPENAI_API_KEY
#
# DeepSeek:
# llm:
#   provider: "deepseek"
#   model: "deepseek-chat"
#   api_key: ""                                 # 或设置环境变量 DEEPSEEK_API_KEY
#   base_url: "https://api.deepseek.com"
#
# Kimi (Moonshot AI):
# llm:
#   provider: "kimi"
#   model: "moonshot-v1-128k"
#   api_key: ""                                 # 或设置环境变量 MOONSHOT_API_KEY
#   base_url: "https://api.moonshot.cn/v1"
